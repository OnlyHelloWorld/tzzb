# 数据库配置
DB_DRIVER=sqlite  # mysql | sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tzzb

# JWT 配置
JWT_SECRET=your-secret-key  # 生产环境请使用强随机字符串
JWT_EXPIRE_HOURS=87600  # 10年

# 服务配置
HOST=0.0.0.0
PORT=8000

# SMTP 邮件配置（QQ 邮箱）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-password  # QQ 邮箱授权码
# 兼容旧变量名（二选一即可；优先读取 SMTP_*）
# QQ_EMAIL=your-email@qq.com
# QQ_AUTH_CODE=your-smtp-password

# 日志配置
LOG_DIR=logs
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10
LOG_RETENTION_DAYS=10
